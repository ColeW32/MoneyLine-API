# Database
# Local Docker Mongo example:
# MONGODB_URI=mongodb://127.0.0.1:27017/moneyline
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=moneyline

# Cache / Rate Limiting
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Internal data sources (never expose)
DATA_SOURCE_A_KEY=
DATA_SOURCE_A_BASE_URL=
DATA_SOURCE_B_KEY=
DATA_SOURCE_B_BASE_URL=
ODDS_API_REGIONS=us,us2,us_ex,us_dfs
ODDS_API_PROP_REGIONS=us,us2,us_dfs
ODDS_API_INCLUDE_PLAYER_PROPS=true
ODDS_API_EVENT_MARKETS_PER_REQUEST=8
ODDS_API_EVENT_ODDS_CONCURRENCY=2
ODDS_API_EVENT_ODDS_DELAY_MS=150

# API Server
NODE_ENV=development
API_PORT=3000
API_SECRET=change-me-to-a-random-string
ML_LIVE_API_KEY=
ML_TEST_API_KEY=ml_test_pro_local

# Auth (Supabase — get from Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

# Email (Phase 2)
RESEND_API_KEY=
FROM_EMAIL=noreply@moneylineapi.com

# Payments (Phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
