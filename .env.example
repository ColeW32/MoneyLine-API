# Database
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=moneyline

# Cache / Rate Limiting
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Internal data sources (never expose)
DATA_SOURCE_A_KEY=
DATA_SOURCE_A_BASE_URL=
DATA_SOURCE_B_KEY=
DATA_SOURCE_B_BASE_URL=

# API Server
NODE_ENV=development
API_PORT=3000
API_SECRET=change-me-to-a-random-string

# Auth (Supabase — get from Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

# Email (Phase 2)
RESEND_API_KEY=
FROM_EMAIL=noreply@moneylineapi.com

# Payments (Phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
