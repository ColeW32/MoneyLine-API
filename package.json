{
  "name": "moneyline-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Unified sports data API — scores, odds, edge data",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/**/*.test.js",
    "seed": "node scripts/seed.js",
    "db:up": "docker compose up -d mongo",
    "db:down": "docker compose down",
    "dev:key": "node scripts/createDevApiKey.js",
    "smoke:api": "node scripts/smokeApi.js",
    "indexes": "node scripts/createIndexes.js",
    "backfill:player-stats": "node scripts/backfillPlayerStats.js",
    "verify:player-stats": "node scripts/verifyPlayerStatsIntegrity.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@upstash/redis": "^1.34.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.12.0",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3"
  }
}
